# Copy this file to secrets.toml (gitignored) and fill in the real values.
#
# Usage:
#   epaper-dashboard-service --config examples/dashboard_config.toml \
#                            --secrets examples/secrets.toml
#
# Values defined here replace ${key} placeholders anywhere in dashboard_config.toml.

[secrets]

# Google Calendar — Settings → [calendar] → Integrate calendar →
# "Secret address in iCal format"
gcal_url = "https://calendar.google.com/calendar/ical/YOUR_CALENDAR_ID/private-XXXX/basic.ics"

# Waste collection address used by the FFB waste source
waste_address = "Ringstr. 12"

# MQTT broker credentials (optional — only needed when the broker requires auth)
# mqtt_password = "your-mqtt-password"
